# Dependencias
# Nunca subas node_modules, es muy pesado y se regenera con 'npm install'
node_modules/
jspm_packages/

# Producción / Builds
# Aquí es donde React guarda la app compilada para subir al servidor
dist/
build/
out/

# Variables de Entorno (SEGURIDAD)
# Evita subir tus llaves de API o secretos de Firebase/Base de datos
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Editor / Sistema Operativo
.vscode/
.idea/
.DS_Store
thumbs.db

# Testing
/coverage